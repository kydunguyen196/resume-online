# Optional - canonical public site URL for metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional - stable external resume URL. Defaults to /assets/resume.pdf
NEXT_PUBLIC_RESUME_URL=

# Required - Resend API key for the contact form
RESEND_API_KEY=

# Optional - WebSocket server URL for realtime features (live cursors, chat, presence)
# Leave empty to disable realtime features entirely
NEXT_PUBLIC_WS_URL=

# Optional - Umami analytics
UMAMI_DOMAIN=
UMAMI_SITE_ID=
